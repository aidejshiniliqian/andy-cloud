<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.andy.passport.mapper.SystemUserRoleMapper">

    <!-- 根据用户ID查询角色列表 -->
    <select id="selectRolesByUserId" resultType="com.andy.passport.entity.SystemRole">
        SELECT r.*
        FROM system_role r
        JOIN system_user_role ur ON r.id = ur.role_id
        ${ew.customSqlSegment}
    </select>

</mapper>
